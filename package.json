{
  "name": "@narai/coding-agent-hub",
  "version": "0.2.2",
  "description": "MCP server hub for coding agent CLIs — invoke Claude, Gemini, or Codex from any MCP client",
  "type": "module",
  "bin": {
    "coding-agent-hub": "./dist/index.js"
  },
  "main": "./dist/hub-server.js",
  "types": "./dist/hub-server.d.ts",
  "exports": {
    ".": {
      "types": "./dist/hub-server.d.ts",
      "import": "./dist/hub-server.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./backends": {
      "types": "./dist/backends.d.ts",
      "import": "./dist/backends.js"
    },
    "./session-manager": {
      "types": "./dist/session-manager.d.ts",
      "import": "./dist/session-manager.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "verify:agents": "tsx scripts/verify-agent-params.ts",
    "check:upstream-versions": "tsx scripts/check-upstream-versions.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "mcp",
    "claude",
    "gemini",
    "codex",
    "coding-agent",
    "ai"
  ],
  "author": "Narai Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/narailabs/coding-agent-hub.git"
  },
  "homepage": "https://github.com/narailabs/coding-agent-hub#readme",
  "bugs": {
    "url": "https://github.com/narailabs/coding-agent-hub/issues"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  }
}
